# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (page /admin — ne pas committer la vraie valeur)
ADMIN_PASSWORD=choisissez-un-mot-de-passe-fort

# WhatsApp — notification à l'entreprise à chaque commande payée
# Option simple (gratuit) : callmebot — voir README
# Option pro : meta (WhatsApp Business Cloud API)
WHATSAPP_PROVIDER=
# Numéro qui reçoit l'alerte (ex. +2250700000000). Sinon = WhatsApp des paramètres admin
WHATSAPP_NOTIFY_PHONE=
# CallMeBot (si WHATSAPP_PROVIDER=callmebot)
WHATSAPP_CALLMEBOT_API_KEY=
# Meta Cloud API (si WHATSAPP_PROVIDER=meta)
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
